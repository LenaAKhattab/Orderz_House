# Copy to .env and fill in real values locally or in your host's secret store.
# Never commit .env or paste production secrets into the repo.

PORT=5000
NODE_ENV=development

# Never set in production. When true (and NODE_ENV is not production), API error JSON may include debug.message/stack.
EXPOSE_ERROR_DEBUG=false

# Required for the API to start (production exits if missing)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/orderz_house
JWT_SECRET=your_jwt_secret_at_least_16_characters
JWT_EXPIRES_IN=7d

# Browser origin for Stripe success/cancel redirects — MUST be a single URL (first segment used).
# For multiple CORS origins (www + apex), set CLIENT_URL to the canonical site and add the rest here:
# CLIENT_URL=https://orderzhouse.com
# CORS_ORIGINS=https://www.orderzhouse.com
#
# SPA origin(s) for CORS with credentials — must match the browser URL exactly (comma-separated for multiple).
# Example: http://localhost:5173,http://127.0.0.1:5173
CLIENT_URL=http://localhost:5173
# CORS_ORIGINS=

# HttpOnly auth cookie uses Secure in production (HTTPS). On local HTTP set COOKIE_SECURE=0 even if NODE_ENV=production.
# COOKIE_SECURE=0

# Email (Resend) — register & forgot-password OTP
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM="Orderz House <no-reply@example.com>"

# Optional — set to 1 when behind a reverse proxy (rate limits + client IP)
# TRUST_PROXY=1

# Freelancer subscription checkout: Stripe Checkout Sessions use dynamic `price_data` from DB `plans.price_jod`
# (no STRIPE_*_PRICE_ID env for that flow). You still need STRIPE_SECRET_KEY for the API to create sessions.
# Optional — payments (leave unset if not using Stripe yet)
# STRIPE_SECRET_KEY=your_stripe_secret_key_here
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret_here
# Local webhooks: stripe listen --forward-to localhost:5000/api/webhooks/stripe (paste printed signing secret here).

# Optional — log safe diagnostics for POST /api/freelancer/subscriptions/checkout (even in production when set)
# DEBUG_FREELANCER_CHECKOUT=1

# Optional — file uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Fake training orders — in-process automation (setInterval). Default OFF (safe for multi-instance production).
# Enable only on a single Node process, or use internal cron endpoint instead (see below).
# FAKE_ORDERS_AUTOMATION_ENABLED=true
# FAKE_ORDERS_TICK_MS=60000
# Verbose JSON logs for skipped_not_due / expiry row counts (noisy).
# FAKE_ORDERS_AUTOMATION_VERBOSE=false
#
# Optional: POST /api/internal/fake-orders/automation-tick with header X-Fake-Orders-Automation-Secret
# (run from pg_cron, system cron, or a single worker). Requires ≥16 chars.
# FAKE_ORDERS_AUTOMATION_CRON_SECRET=

# PostHog — event capture SDK (posthog-node) and server-side HogQL queries
# POSTHOG_API_KEY: project API key (public token, starts with phc_) — used by posthog-node to send events
# POSTHOG_HOST: ingestion API host only — https://us.i.posthog.com or https://eu.i.posthog.com (NOT https://us.posthog.com)
# POSTHOG_PROJECT_ID: numeric project id — used by server-side HogQL proxy only
# POSTHOG_PERSONAL_API_KEY: personal API key with query permission — used by server-side HogQL proxy only
# POSTHOG_API_KEY=
# POSTHOG_HOST=
# POSTHOG_PROJECT_ID=
# POSTHOG_PERSONAL_API_KEY=
