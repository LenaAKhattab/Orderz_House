VITE_API_BASE_URL=http://localhost:5000/api

# PostHog — project API key (safe for browser). Never put personal API keys here.
VITE_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
