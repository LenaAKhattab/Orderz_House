VITE_API_BASE_URL=http://localhost:5000/api

# PostHog — project API key (safe for browser). Never put personal API keys here.
VITE_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# US cloud: https://us.i.posthog.com — EU cloud: https://eu.i.posthog.com (NOT us.posthog.com dashboard URL)
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Optional: set true only when you want events while running `vite` locally.
VITE_POSTHOG_ENABLE_IN_DEV=false

